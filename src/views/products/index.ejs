<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StoreJS — Products</title>
    <style>
      body { background: #0d1117; color: #c9d1d9; font-family: "Segoe UI", system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; }
      h1 { color: #f0883e; border-bottom: 1px solid #30363d; padding-bottom: 8px; }
      a { color: #58a6ff; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .btn { display: inline-block; background: #238636; color: #fff; padding: 8px 16px; border-radius: 6px; text-decoration: none; margin: 2px 0; }
      .btn:hover { background: #2ea043; text-decoration: none; }
      ul { list-style: none; padding: 0; }
      li { background: #161b22; margin: 8px 0; padding: 16px; border-radius: 8px; border: 1px solid #30363d; display: flex; justify-content: space-between; align-items: center; }
      li:hover { border-color: #58a6ff; }
      .empty { color: #8b949e; font-style: italic; padding: 40px 0; text-align: center; }
      .nav { margin-bottom: 24px; padding: 12px 0; border-bottom: 1px solid #30363d; }
      .nav a { margin-right: 16px; }
      .notice { background: #1f2937; border-left: 4px solid #58a6ff; padding: 10px 16px; border-radius: 4px; margin-bottom: 16px; }
      .hero { background: linear-gradient(135deg, #161b22 0%, #0d1117 100%); border: 1px solid #30363d; border-radius: 12px; padding: 32px; margin-bottom: 24px; text-align: center; }
      .hero h2 { color: #f0883e; margin: 0 0 8px 0; font-size: 24px; }
      .hero p { color: #8b949e; margin: 0; }
      .stats { display: flex; gap: 16px; margin: 20px 0; }
      .stat { flex: 1; background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 16px; text-align: center; }
      .stat .number { font-size: 28px; font-weight: bold; color: #58a6ff; }
      .stat .label { font-size: 12px; color: #8b949e; text-transform: uppercase; letter-spacing: 1px; }
    </style>
  </head>
  <body>
    <div class="nav">
      <a href="/products" class="btn">🏪 Products</a>
      <a href="/products/new" class="btn">+ New</a>
      <a href="/about">About</a>
    </div>

    <% if (notice) { %>
      <div class="notice"><%= notice %></div>
    <% } %>

    <div class="hero">
      <h2>🏪 StoreJS</h2>
      <p>Your friendly neighborhood product catalog</p>
    </div>

    <div class="stats">
      <div class="stat">
        <div class="number"><%= products.length %></div>
        <div class="label">Products</div>
      </div>
      <div class="stat">
        <div class="number">∞</div>
        <div class="label">Possibilities</div>
      </div>
      <div class="stat">
        <div class="number">🛩️</div>
        <div class="label">Powered by</div>
      </div>
    </div>

    <h1>Products</h1>

    <% if (products.length === 0) { %>
      <p class="empty">No products yet. Create your first one!</p>
    <% } %>

    <ul>
      <% products.forEach(function(product) { %>
        <li>
          <span><%= product.name %></span>
          <a href="/products/<%= product.id %>" class="btn">View →</a>
        </li>
      <% }) %>
    </ul>
  </body>
</html>
